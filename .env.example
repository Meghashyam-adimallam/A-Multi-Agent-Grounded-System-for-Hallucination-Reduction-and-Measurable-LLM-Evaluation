# Multi-Agent Grounded RAG System — Environment Variables
# Copy to .env and fill in values

# OpenAI (for Answer Generator, Claim Decomposer)
OPENAI_API_KEY=sk-...

# Langfuse (optional — for observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Vector store: faiss | chromadb
VECTOR_STORE=faiss

# LLM: openai | local
LLM_PROVIDER=openai
